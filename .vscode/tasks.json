{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "HA Start",
      "type": "shell",
      "command": "docker compose up -d",
      "options": {
        "cwd": "${workspaceFolder}/../ha-dev"
      },
      "problemMatcher": []
    },
    {
      "label": "HA Restart",
      "type": "shell",
      "command": "docker compose restart homeassistant && sleep 3",
      "options": {
        "cwd": "${workspaceFolder}/../ha-dev"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "HA Stop",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}/../ha-dev"
      },
      "problemMatcher": []
    },
    {
      "label": "HA Logs",
      "type": "shell",
      "command": "docker compose logs -f homeassistant",
      "options": {
        "cwd": "${workspaceFolder}/../ha-dev"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "HA Stop + Start + Logs",
      "dependsOrder": "sequence",
      "dependsOn": [
        "HA Stop",
        "HA Start",
        "HA Logs"
      ],
      "problemMatcher": []
    }
  ]
}